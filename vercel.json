{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist/public",
    "framework": null,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 30,
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api"
        },
        {
            "source": "/:path*",
            "destination": "/api"
        }
    ]
}
